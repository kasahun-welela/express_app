pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Building your VS Code Hello World project...'
            }
        }

        stage('Code Quality') {
            steps {
                echo 'Running code quality checks...'
            }
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Project successfully executed via Jenkinsfile!'
            }
        }
    }
}